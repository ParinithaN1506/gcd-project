rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // NGO Validation
    function isValidNGO(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.description is string && data.description.size() <= 2000 &&
             data.ownerId == request.auth.uid;
    }

    match /ngos/{ngoId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(ngoId) && isValidNGO(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing().ownerId) && isValidNGO(incoming()) && 
                    incoming().ownerId == existing().ownerId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'services', 'needs', 'location', 'contact']);
      allow delete: if isSignedIn() && isOwner(existing().ownerId);
    }

    // Crisis Validation
    function isValidCrisis(data) {
      return data.title is string && data.title.size() > 0 &&
             data.urgency in ['low', 'medium', 'high', 'critical'] &&
             data.reporterId == request.auth.uid;
    }

    match /crises/{crisisId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(crisisId) && isValidCrisis(incoming());
      allow update: if isSignedIn() && (
        isOwner(existing().reporterId) || 
        // Allow anyone to update status if they are an NGO owner? Maybe just NGOs can update status
        exists(/databases/$(database)/documents/ngos/$(request.auth.uid))
      ) && isValidCrisis(incoming()) &&
      incoming().reporterId == existing().reporterId;
      allow delete: if isSignedIn() && isOwner(existing().reporterId);

      match /updates/{updateId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidId(updateId) && 
                      exists(/databases/$(database)/documents/ngos/$(incoming().ngoId)) &&
                      get(/databases/$(database)/documents/ngos/$(incoming().ngoId)).data.ownerId == request.auth.uid;
        allow update, delete: if isSignedIn() && 
                              get(/databases/$(database)/documents/ngos/$(existing().ngoId)).data.ownerId == request.auth.uid;
      }
    }

    // Donation Validation
    match /donations/{donationId} {
      allow read: if isSignedIn() && (isOwner(resource.data.donorId) || exists(/databases/$(database)/documents/ngos/$(resource.data.ngoId)));
      allow create: if isSignedIn() && incoming().donorId == request.auth.uid;
    }
  }
}
